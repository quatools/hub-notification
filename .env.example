# Supabase (même instance que le BAAS)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxx...
SUPABASE_SERVICE_ROLE_KEY=eyJxxxx...

# SMTP (email transactionnel) - provider-agnostique
# Compatible Scaleway TEM, Brevo, OVH, etc.
# Port 465 = TLS implicite, 587 = STARTTLS
SMTP_HOST=smtp.tem.scaleway.com
SMTP_PORT=587
SMTP_USER=xxxx
SMTP_PASS=xxxx
SMTP_FROM=Quatools Notifications <notifications@quatools.fr>

# API Keys des apps autorisées (JSON)
# Format: {"app-name": "api-key-secret"}
NOTIFICATION_API_KEYS={"baas-esport":"change-me"}

# Scaleway (API TEM pour les domaines d'envoi marque blanche)
SCW_SECRET_KEY=xxxx
SCW_DEFAULT_PROJECT_ID=xxxx
SCW_REGION=fr-par

# Secret de signature des access tokens OAuth du serveur MCP (>=32 caractères)
MCP_OAUTH_SECRET=change-me-with-a-long-random-string

# Bot Discord "Notify" (canal MP Discord)
NEXT_PUBLIC_DISCORD_APP_ID=xxxx
DISCORD_BOT_TOKEN=xxxx
